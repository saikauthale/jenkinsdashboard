pipeline {
    agent any

    stages {

        stage('Clone') {
            steps {
                git 'https://github.com/username/dashboard-project.git'
            }
        }

        stage('Deploy') {
            steps {
                sh 'sudo cp index.html /var/www/html/'
                sh 'sudo cp style.css /var/www/html/'
            }
        }
    }
}
